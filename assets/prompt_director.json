NG","type":"STRING","links":[15]}],"title":"Indoor - soft","properties":{"cnr_id":"tbg-etur","ver":"e570878f03fbcb44ad98ef1de39253a0aa4ea8b3","Node name for S&R":"Text Multiline","ue_properties":{"widget_ue_connectable":{},"input_ue_unconnectable":{},"version":"7.5.2"}},"widgets_values":["Soft indoor ambient illumination, warm even glow from above, ceiling acts as a diffuse reflector, no harsh shadows, gentle gradient from upper to lower walls, intimate and even exposure, warm neutral color temperature, surfaces lit as if by reflected indirect light.\n"]},{"id":31,"type":"Text Multiline","pos":[375.54025381730975,711.5389706912023],"size":[400,200],"flags":{"collapsed":true},"order":4,"mode":0,"inputs":[{"localized_name":"text","name":"text","type":"STRING","widget":{"name":"text"},"link":null}],"outputs":[{"localized_name":"STRING","name":"STRING","type":"STRING","links":[14]}],"title":"Indoor - Dark","properties":{"cnr_id":"tbg-etur","ver":"e570878f03fbcb44ad98ef1de39253a0aa4ea8b3","Node name for S&R":"Text Multiline","ue_properties":{"widget_ue_connectable":{},"input_ue_unconnectable":{},"version":"7.5.2"}},"widgets_values":["Dark interior, single weak practical light source, warm tungsten spill on nearby surfaces, deep cool shadow fill, high contrast between lit and unlit areas, eyes-adjusted dimness, details emerge only where light grazes surfaces, cinematic available light photography."]},{"id":38,"type":"Text Multiline","pos":[361.76889146965794,658.6642579414483],"size":[400,200],"flags":{"collapsed":true},"order":5,"mode":0,"inputs":[{"localized_name":"text","name":"text","type":"STRING","widget":{"name":"text"},"link":null}],"outputs":[{"localized_name":"STRING","name":"STRING","type":"STRING","links":[11]}],"title":"Outdoor - Sunny","properties":{"cnr_id":"tbg-etur","ver":"e570878f03fbcb44ad98ef1de39253a0aa4ea8b3","Node name for S&R":"Text Multiline","ue_properties":{"widget_ue_connectable":{},"input_ue_unconnectable":{},"version":"7.5.2"}},"widgets_values":["Bright sunny afternoon outdoors, intense natural sunlight, clear blue sky, harsh direct shadows with high contrast, vivid colors, sharp sunlight highlights and deep cast shadows from objects and trees, golden-hour adjacent warmth if desired but full midday punch, strong volumetric rays if through leaves or structures.\n\n"]},{"id":36,"type":"Text Multiline","pos":[363.0458751894129,603.3913699070536],"size":[400,200],"flags":{"collapsed":true},"order":6,"mode":0,"inputs":[{"localized_name":"text","name":"text","type":"STRING","widget":{"name":"text"},"link":null}],"outputs":[{"localized_name":"STRING","name":"STRING","type":"STRING","links":[10]}],"title":"Outdoor - Dark","properties":{"cnr_id":"tbg-etur","ver":"e570878f03fbcb44ad98ef1de39253a0aa4ea8b3","Node name for S&R":"Text Multiline","ue_properties":{"widget_ue_connectable":{},"input_ue_unconnectable":{},"version":"7.5.2"}},"widgets_values":["Night exterior. Deeply underexposed blue-hour aesthetic. The scene is dominated by heavy crushed blacks and a thick atmospheric gloom. Subject is a murky silhouette with only the faintest low-key cool spill defining the edges of the form. Muted, muddy desaturated tones. Heavy natural film grain and sensor noise. Visuals prioritize a \"missing information\" look where the subject is nearly lost to the shadows. Zero highlight detail. Environmental occlusion where the woods and the figure bleed together into a singular dark mass."]},{"id":40,"type":"Text Multiline","pos":[365.2592417422024,550.5754961918597],"size":[400,200],"flags":{"collapsed":true},"order":7,"mode":0,"inputs":[{"localized_name":"text","name":"text","type":"STRING","widget":{"name":"text"},"link":null}],"outputs":[{"localized_name":"STRING","name":"STRING","type":"STRING","links":[7]}],"title":"Wooded area","properties":{"cnr_id":"tbg-etur","ver":"e570878f03fbcb44ad98ef1de39253a0aa4ea8b3","Node name for S&R":"Text Multiline","ue_properties":{"widget_ue_connectable":{},"input_ue_unconnectable":{},"version":"7.5.2"}},"widgets_values":["Set in a wooded area. Private, but known space shows signs of use featuring an item of trash.\n\n\n"]},{"id":34,"type":"Text Multiline","pos":[374.6423603243681,496.4202751891903],"size":[400,200],"flags":{"collapsed":true},"order":8,"mode":0,"inputs":[{"localized_name":"text","name":"text","type":"STRING","widget":{"name":"text"},"link":null}],"outputs":[{"localized_name":"STRING","name":"STRING","type":"STRING","links":[9]}],"title":"luxury hotel","properties":{"cnr_id":"tbg-etur","ver":"e570878f03fbcb44ad98ef1de39253a0aa4ea8b3","Node name for S&R":"Text Multiline","ue_properties":{"widget_ue_connectable":{},"input_ue_unconnectable":{},"version":"7.5.2"}},"widgets_values":["A spacious modern luxury hotel suite featuring Floor-to-ceiling windows with expansive city views, heavy neutral-toned curtains frame the glass. Marble-topped surfaces and flooring.\n\n"]},{"id":35,"type":"Text Multiline","pos":[375.5782053074149,443.4890966120437],"size":[400,200],"flags":{"collapsed":true},"order":9,"mode":0,"inputs":[{"localized_name":"text","name":"text","type":"STRING","widget":{"name":"text"},"link":null}],"outputs":[{"localized_name":"STRING","name":"STRING","type":"STRING","links":[5]}],"title":"Building side","properties":{"cnr_id":"tbg-etur","ver":"e570878f03fbcb44ad98ef1de39253a0aa4ea8b3","Node name for S&R":"Text Multiline","ue_properties":{"widget_ue_connectable":{},"input_ue_unconnectable":{},"version":"7.5.2"}},"widgets_values":["A narrow urban alley beside a weathered brick building, faded painted advertisement on the wall, rusted fire escape, cracked asphalt, scattered debris, metal dumpster, exposed conduit and utility pipes, ambient city glow from the street beyond."]},{"id":39,"type":"Text Multiline","pos":[375.3966213831569,388.7983883905989],"size":[400,200],"flags":{"collapsed":true},"order":10,"mode":0,"inputs":[{"localized_name":"text","name":"text","type":"STRING","widget":{"name":"text"},"link":null}],"outputs":[{"localized_name":"STRING","name":"STRING","type":"STRING","links":[6]}],"title":"kitchen","properties":{"cnr_id":"tbg-etur","ver":"e570878f03fbcb44ad98ef1de39253a0aa4ea8b3","Node name for S&R":"Text Multiline","ue_properties":{"widget_ue_connectable":{},"input_ue_unconnectable":{},"version":"7.5.2"}},"widgets_values":["A typical middle-class American suburban kitchen, white shaker-style cabinets, Standard stainless steel appliances, quartz countertops in neutral tones, subway tile backsplash.\n\n"]},{"id":43,"type":"Text Multiline","pos":[384.036138594112,337.7642447129057],"size":[400,200],"flags":{"collapsed":true},"order":11,"mode":0,"inputs":[{"localized_name":"text","name":"text","type":"STRING","widget":{"name":"text"},"link":null}],"outputs":[{"localized_name":"STRING","name":"STRING","type":"STRING","links":[21]}],"title":"Night - Crisp Subject","properties":{"cnr_id":"tbg-etur","ver":"e570878f03fbcb44ad98ef1de39253a0aa4ea8b3","Node name for S&R":"Text Multiline","ue_properties":{"widget_ue_connectable":{},"input_ue_unconnectable":{},"version":"7.5.2"}},"widgets_values":["Soft-focus depth, low-key lighting, murky silhouettes, atmospheric density. The rendering prioritizes diffuse, low-energy light interaction across organic surfaces. Light exhibits natural subsurface scattering with zero specular highlights, allowing geometry to be defined by shadow rather than reflection. The transition between the subject and the background is characterized by a heavy, underexposed roll-off and environmental bleeding, preserving the structural integrity of the dark space without artificial edge sharpening.\n\n"]},{"id":42,"type":"PrimitiveString","pos":[390.04693342596863,278.61111540373304],"size":[270,58],"flags":{"collapsed":true},"order":12,"mode":0,"inputs":[{"localized_name":"value","name":"value","type":"STRING","widget":{"name":"value"},"link":null}],"outputs":[{"localized_name":"STRING","name":"STRING","type":"STRING","links":[18]}],"title":"Low DOF","properties":{"cnr_id":"comfy-core","ver":"0.6.0","Node name for S&R":"PrimitiveString","ue_properties":{"widget_ue_connectable":{},"input_ue_unconnectable":{},"version":"7.5.2"}},"widgets_values":["Selective focus, creamy bokeh transitions, organic subject isolation, naturalistic depth compression, soft-fringe highlights, 8k professional optics.  The rendering emphasizes a shallow focal plane where the subject remains tack-sharp against a non-linear background blur. Light fall-off is smooth and continuous, avoiding stepping artifacts. Specular points in the defocused areas resolve into soft, circular out-of-focus elements, while the primary subject maintains high micro-contrast and textural clarity."]},{"id":45,"type":"Text Multiline","pos":[385.14343803217355,227.6096655871148],"size":[380.74122303176705,88],"flags":{"collapsed":true},"order":13,"mode":0,"inputs":[{"localized_name":"text","name":"text","type":"STRING","widget":{"name":"text"},"link":null}],"outputs":[{"localized_name":"STRING","name":"STRING","type":"STRING","links":[19]}],"title":"Day - Crisp Subject","properties":{"cnr_id":"tbg-etur","ver":"e570878f03fbcb44ad98ef1de39253a0aa4ea8b3","Node name for S&R":"Text Multiline","ue_properties":{"widget_ue_connectable":{},"input_ue_unconnectable":{},"version":"7.5.2"}},"widgets_values":["Ultra-sharp focus, high-contrast edges, defined silhouettes, macro detail, cinematic lighting.\n\nThe rendering prioritizes anisotropic light interaction across organic surfaces. Light exhibits natural subsurface scattering and specular highlights that define the geometry of the subject. The transition between the subject and the background maintains a soft depth-of-field roll-off, preserving edge integrity without artificial sharpening.\n\n\n\n"]},{"id":53,"type":"MarkdownNote","pos":[517.1220672806288,806.8730155299143],"size":[340.9691355665848,157.3385834418482],"flags":{},"order":14,"mode":0,"inputs":[],"outputs":[],"title":".","properties":{"ue_properties":{"widget_ue_connectable":{}